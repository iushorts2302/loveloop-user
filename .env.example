# Loveloop AI — 환경변수 예시 (실제 값은 Vercel Environment Variables 에만 입력)
# 이 파일에는 절대 실제 비밀번호를 적지 마세요. 커밋되는 파일입니다.
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=14157
DB_USER=avnadmin
DB_PASSWORD=__SET_IN_VERCEL_ONLY__
DB_NAME=loveloop_db
# Aiven 콘솔에서 받은 CA 인증서 전체를 한 줄(또는 멀티라인)로 넣으면 TLS 검증 강화
DB_CA_CERT=
